# privacy-relayer — runtime configuration (docker compose reads this as env_file).
# Copy to `.env` and edit. All values map to the `serve` subcommand via clap env.

# ── Required ──────────────────────────────────────────────────────────────────
# Ethereum JSON-RPC (HTTP/HTTPS).
PRIVACYBTC_ETH_RPC_URL=https://your-rpc.example.com
# Chain id of the network above.
PRIVACYBTC_CHAIN_ID=1
# Relayer EOA private key (hex secp256k1). Pays gas for /submit_raw broadcasts.
# KEEP SECRET — do not commit your real .env.
PRIVACYBTC_RELAYER_PRIVATE_KEY=0xchange-me
# Primary contract address (factory or primary pool). /submit_raw can target any
# runtime-registered pool, but `serve` requires a contract to start.
PRIVACYBTC_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the relayer (your web app).
PRIVACYBTC_CORS_ORIGINS=https://app.example.com

# ── Gas tuning (optional) ─────────────────────────────────────────────────────
#PRIVACYBTC_GAS_PRICE_GWEI=1.0
#PRIVACYBTC_GAS_LIMIT_SHIELD=3000000
#PRIVACYBTC_GAS_LIMIT_TRANSFER=5000000
#PRIVACYBTC_GAS_LIMIT_UNSHIELD=3000000

# ── Optional integrations ─────────────────────────────────────────────────────
# Notify the indexer of broadcast tx hashes (faster note pickup).
#PRIVACYBTC_INDEXER_URL=http://indexer:8787

# Host port to expose the relayer on (container always listens on 8790).
RELAYER_HOST_PORT=8790
